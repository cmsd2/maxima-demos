215,-1.2836421562927385,-1.2666829621944282,-1.2497905830190805,-1.232964459008973,-1.2162040372992238,-1.1995087718048287,-1.1828781231101024,-1.1663115583598778,-1.1498085511535634,-1.1333685814407415,-1.1169911354192659],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"#377eb8\",\"width\":2},\"name\":\"Order 8\"}],\"layout\":{\"title\":{\"text\":\"Approximation Error: log10(|exp(x) - T_n(x)|)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"log10(error)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
