0851,30.460686472251915,30.87252908723728,31.28921594769293,31.710792847683667,32.1373058861699,32.56880146806674,33.005326305303186,33.44692741788118,33.89365213493477,34.34554809578924,34.80266325102023,35.265045863512825,35.73274450952075,36.20580807972542,36.6842857802951,37.16822713394409,37.657681980991725,38.152700480421586,38.65333311094061,39.15963067203818,39.67164428504533,40.18942539419378,40.71302576767511,41.24249749869988,41.777893006556745,42.319265037671585,42.86666666666664],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"red\",\"width\":2,\"dash\":\"dash\"},\"name\":\"Taylor O(5)\"}],\"layout\":{\"title\":{\"text\":\"exp(x) vs Taylor Polynomial (order 5)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"range\":[-1.0,20.0],\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
