674893885,0.06555410267563472,0.06530076732336124,0.06505019152471564,0.06480230861516792,0.06455705433004345,0.06431436670589567,0.0640741859860811,0.06383645453035701,0.0636011167283296,0.06336811891658786,0.0631374092993652,0.0629089378725778,0.06268265635109482,0.062458518099102064,0.062236478063426214,0.06201649270969274],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"#e41a1c\",\"width\":2},\"showlegend\":false,\"hoverinfo\":\"skip\"}],\"layout\":{\"title\":{\"text\":\"Predator-Prey: Phase Portrait\"},\"width\":700,\"height\":700,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x (prey)\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y (predator)\"},\"scaleanchor\":\"x\",\"scaleratio\":1,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
