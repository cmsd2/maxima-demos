              "\\ifx\\endpmatrix\\undefined\\pmatrix{\\else\\begin{pmatrix}\\fi 1.0&0.8269329360637584&-0.021769619911851976&-0.716420184379767\\cr0.8269329360637584&1.0&-0.053081369397880426&-0.6169110276147319\\cr -0.021769619911851976&-0.053081369397880426&1.0&0.7130999186596808\\cr -0.716420184379767&-0.6169110276147319&0.7130999186596808&1.0\\cr\\ifx\\endpmatrix\\undefined}\\else\\end{pmatrix}\\fi "
