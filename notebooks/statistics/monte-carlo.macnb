7762723460413,0.47017162250567607,0.4740952279706811,0.5491122731625968,0.5177713653585655,0.425755261217252,0.4046431333424182,0.45214604574434375,0.4498695366474035,0.47059313177078294,0.4502727604795506,0.519480946972676,0.5253312470347273,0.5344086672238836,0.470788382650275,0.45080701367783876,0.48221686339608],\"type\":\"histogram\",\"marker\":{\"color\":\"steelblue\"},\"nbinsx\":40,\"name\":\"histogram\"}],\"layout\":{\"title\":{\"text\":\"Central Limit Theorem: Distribution of Sample Means\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Sample Mean\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Count\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
