07,0.6244400510426331,0.954911411148514,0.7326888691418643,0.9605276646399272,0.9220352353920147,0.40017344160290635,0.9611705220967959,0.6761888434435781,0.8404414069106516,0.7484290573098611,0.6760287827286595,0.7363444670152937,0.7305261915004211,0.8899695726137229,0.15854395109522668,0.9352213055832315,0.6501916381804476,0.3694758006100993,0.5447238130569412,0.8354918177693624,0.7309422417008193,0.9263114875356973,0.7099371056861661,0.9506717395976283,0.9729124012365062,0.8791633116802045,0.6982322831275154,0.47018444373552737,0.8792317579354474,0.9264556788466569,0.9005677899123457,0.996081516693321,0.9848859059469393,0.41298229453180113,0.8851226840275841,0.8182405842905862,0.45411422643690313,0.7343099287804695,0.5403611294371793,0.8442447366790824,0.890643198669377,0.7767867158448922,0.598495107224255,0.664746913286197,0.765214502407447,0.6886585753146857,0.8993095746300355,0.934005362866422,0.9521041876629579,0.38914537660052395,0.8041657586244475,0.9402284541435233,0.9355602455515819,0.9599635307768337,0.636792609461537,0.9907317751780194,0.6545496599569083,0.864220609243469,0.9333553881857355,0.7895004754793895,0.9224285952120952,0.6006895877610483,0.945839117244154,0.691782694394858,0.6931462383538338,0.9564560625820688,0.9986100272512783,0.9563825176894474,0.7816711070293341,0.841122176674125,0.5829312329302108,0.9272599826007988,0.6574538417790665,0.6054329746394778,0.8546463481679469,0.6576264598220016,0.9286529734809941,0.9953779640599847,0.9694470207215797,0.8232732759700716,0.9315600929322199,0.5490848549630813,0.4865102785439279,0.45817505826211424],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"red\",\"size\":2},\"name\":\"Outside\"}],\"layout\":{\"title\":{\"text\":\"Pi Estimate: 3.1704 (N=10000)\"},\"width\":700,\"height\":700,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y\"},\"scaleanchor\":\"x\",\"scaleratio\":1,\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## Convergence of the Pi Estimate\n\nAs $N$ increases, the Monte Carlo estimate converges to the true value.\nThe standard error decreases as $O(1/\\sqrt{N})$, which is the hallmark\nconvergence rate of Monte Carlo methods -- independent of dimension.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Run the pi estimation for increasing sample sizes */\nsample_sizes : [100, 500, 1000, 5000, 10000, 50000]$\n\npi_estimates : makelist(\n  block([pts, xx, yy, dd, cc],\n    pts : np_rand([sample_sizes[i], 2]),\n    xx : np_col(pts, 0),\n    yy : np_col(pts, 1),\n    dd : np_sqrt(np_add(np_pow(xx, 2), np_pow(yy, 2))),\n    cc : np_sum(np_less_equal(dd, 1.0)),\n    4.0 * cc / sample_sizes[i]\n  ),\n  i, 1, length(sample_sizes)\n)$\n\nfor i: 1 thru length(sample_sizes) do\n  print(sconcat(\"N = \", string(sample_sizes[i]),\n                \"  estimate = \", string(pi_estimates[i]),\n                \"  error = \", string(abs(pi_estimates[i] - float(%pi)))))$",
      "metadata": {},
      "execution_count": 92,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "N = 100  estimate = 3.12  error = 0.02159265358979301\nN = 500  estimate = 3.032  error = 0.10959265358979309\nN = 1000  estimate = 3.132  error = 0.009592653589792999\nN = 5000  estimate = 3.1584  error = 0.016807346410206758\nN = 10000  estimate = 3.1516  error = 0.010007346410207063\nN = 50000  estimate = 3.1404  error = 0.0011926535897930357"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Plot convergence: estimate vs N, with true pi as reference */\nax_draw2d(\n  color=blue, name=\"MC estimate\",\n  points(sample_sizes, pi_estimates),\n  color=red, dash=\"dash\", name=\"true pi\",\n  lines([[first(sample_sizes), float(%pi)],\n         [last(sample_sizes), float(%pi)]]),\n  title=\"Convergence of Pi Estimate\",\n  xlabel=\"N (sample size)\", ylabel=\"Estimate\",\n  grid=true\n)$",
      "metadata": {},
      "execution_count": 93,
      "outputs": [
        {
          "data": {
            "application/x-maxima-plotly": [
              "{\"data\":[{\"x\":[100.0,500.0,1000.0,5000.0,10000.0,50000.0],\"y\":[3.12,3.032,3.132,3.1584,3.1516,3.1404],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"blue\",\"size\":6},\"name\":\"MC estimate\"},{\"x\":[100.0,50000.0],\"y\":[3.141592653589793,3.141592653589793],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"red\",\"width\":2,\"dash\":\"dash\"},\"name\":\"true pi\"}],\"layout\":{\"title\":{\"text\":\"Convergence of Pi Estimate\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"N (sample size)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Estimate\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## Central Limit Theorem\n\nThe **Central Limit Theorem** states that the mean of $n$ i.i.d. random\nvariables converges to a normal distribution as $n \\to \\infty$,\nregardless of the underlying distribution.\n\nWe demonstrate this with the uniform distribution on $[0,1)$: take many\nsamples of size 30, compute the mean of each, and observe that the\nhistogram of sample means is approximately Gaussian -- even though the\nindividual values are uniformly distributed.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Generate 2000 samples, each of size 30 */\nn_samples : 2000$\nsample_size : 30$\n\n/* Each row is one sample of 30 uniform values */\nsamples : np_rand([n_samples, sample_size])$\n\n/* Compute mean of each row (sample) */\nsample_means : np_mean(samples, 1)$\n\nprint(\"Mean of sample means:\", np_mean(sample_means))$\nprint(\"Std dev of sample means:\", np_std(sample_means))$\nprint(\"Theoretical std dev: 1/sqrt(12*30) =\", float(1/sqrt(12*30)))$",
      "metadata": {},
      "execution_count": 94,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Mean of sample means: 0.49922271176190636\nStd dev of sample means: 0.052802166326814684\nTheoretical std dev: 1/sqrt(12*30) = 0.05270462766947299"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Histogram of sample means -- should look Gaussian */\nax_draw2d(\n  color=\"steelblue\", nbins=40,\n  ax_histogram(sample_means),\n  title=\"Central Limit Theorem: Distribution of Sample Means\",\n  xlabel=\"Sample Mean\", ylabel=\"Count\",\n  grid=true\n)$",
      "metadata": {},
      "execution_count": 95,
      "outputs": [
        {
          "data": {
