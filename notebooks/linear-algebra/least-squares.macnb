89052,1.2861133087818928,1.3075891261480859,1.3291653447174898,1.350841964490101,1.3726189854659214,1.394496407644949,1.416474231027184,1.4385524556126281,1.4607310814012777,1.4830101083931382,1.505389536588206,1.527869365986481,1.5504495965879652,1.5731302283926567,1.5959112614005573,1.6187926956116634,1.6417745310259786,1.6648567676435029,1.6880394054642345,1.7113224444881752,1.7347058847153232,1.7581897261456785,1.7817739687792429,1.8054586126160128,1.8292436576559918,1.85312910389918,1.8771149513455772,1.90120119999518,1.9253878498479935,1.9496749009040126,1.974062353163239,1.9985502066256746,2.0231384612913192,2.047827117160171,2.072616174232232,2.0975056325075006,2.122495491985976,2.147585752667659,2.172776414552551,2.1980674776406506,2.223458941931959,2.2489508074264766,2.2745430741241996,2.3002357420251336,2.326028811129273,2.35192228143662,2.3779161529471757,2.4040104256609407,2.430205099577913,2.4565001746980943,2.4828956510214812,2.509391528548079,2.5359878072778805,2.562684487210893,2.5894815683471144,2.616379050686543,2.6433769342291793,2.6704752189750245,2.697673904924077,2.724972992076335,2.752372480431804,2.77987236999048,2.8074726607523655,2.835173352717458,2.8629744458857598,2.890875940257269,2.918877835831985,2.946980132609907,2.9751828305910415,3.0034859297753815,3.0318894301629307,3.060393331753687,3.0889976345476526,3.1177023385448255,3.146507443745204,3.175412950148793,3.2044188577555897,3.2335251665655953,3.2627318765788083,3.2920389877952303,3.3214465002148597,3.3509544138376928,3.3805627286637385,3.4102714446929916,3.4400805619254538,3.469990080361123,3.5],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"black\",\"width\":2,\"dash\":\"dash\"},\"name\":\"True curve\"}],\"layout\":{\"title\":{\"text\":\"Underfitting vs Overfitting\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y\"},\"range\":[-3.0,6.0],\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
