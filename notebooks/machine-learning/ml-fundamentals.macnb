,0.13362134929188435,0.13338252322710034,0.13314644114489965,0.13291305470527745,0.1326823167248223,0.13245418114172572,0.13222860298207006,0.13200553832734097,0.13178494428311116,0.13156677894884608,0.13135100138878594,0.1311375716038577,0.13092645050457466,0.13071759988488324,0.13051098239691875,0.130306561526632,0.13010430157025213,0.1299041676115523,0.12970612549988653,0.12951014182896559,0.1293161839163441,0.1291242197835912,0.1289342181371167,0.12874614834962853,0.12855998044219696,0.12837568506690203,0.12819323349004189,0.12801259757588154,0.12783374977092068,0.127656663088662,0.12748131109486086,0.12730766789323847,0.12713570811164215,0.12696540688863547,0.12679673986050266,0.12662968314865372,0.12646421334741345,0.12630030751218257,0.12613794314795695,0.12597709819819214,0.12581775103400128,0.1256598804436748,0.12550346562250983,0.12534848616294017,0.12519492204495505,0.12504275362679718,0.12489196163593048,0.12474252716026937,0.12459443163965823,0.1244476568575965,0.12430218493319595,0.12415799831336902,0.12401507976523336,0.12387341236873187],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"darkred\",\"width\":2},\"name\":\"lines\"}],\"layout\":{\"title\":{\"text\":\"Logistic Regression: Cross-Entropy Loss\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Iteration\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Loss\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
