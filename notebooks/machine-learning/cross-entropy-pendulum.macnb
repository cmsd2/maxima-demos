      "source": "/* Phase portrait — higher torque */\nax_draw2d(\n  line_width = 2,\n  color = royalblue,\n  name = \"Trajectory\",\n  lines(map(to_deg, th2),\n        map(lambda([a], a * 180/float(%pi)), om2)),\n  marker_size = 10,\n  color = tomato,\n  name = \"Start (hanging)\",\n  points([180], [0]),\n  color = forestgreen,\n  name = \"Target (upright)\",\n  points([0], [0]),\n  title = \"Phase Portrait: Swing-Up (u_max = 12)\",\n  xlabel = \"theta (deg)\",\n  ylabel = \"omega (deg/s)\",\n  grid = true\n)$",
