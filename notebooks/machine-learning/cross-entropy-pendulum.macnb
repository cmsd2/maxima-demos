    {
      "cell_type": "code",
      "source": "/* Learning curve */\ngens_list : makelist(i, i, 1, n_gens)$\nax_draw2d(\n  line_width = 2,\n  color = royalblue,\n  name = \"Best cost\",\n  lines(gens_list, best_cost_history),\n  color = tomato,\n  dash = \"dash\",\n  name = \"Elite mean\",\n  lines(gens_list, mean_cost_history),\n  title = \"CEM Learning Curve\",\n  xlabel = \"Generation\",\n  ylabel = \"Cost\",\n  grid = true\n)$",
      "metadata": {},
      "execution_count": 12,
      "outputs": [
