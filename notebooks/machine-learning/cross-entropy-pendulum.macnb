      "source": "/* Phase portrait */\nom_opt_list : np_to_list(np_slice(traj_opt, all, 2))$\nax_draw2d(\n  line_width = 2,\n  color = royalblue,\n  name = \"Trajectory\",\n  lines(map(to_deg, th_opt_list),\n        map(lambda([a], a * 180/float(%pi)), om_opt_list)),\n  marker_size = 10,\n  color = tomato,\n  name = \"Start (hanging)\",\n  points([to_deg(float(%pi))], [0]),\n  color = forestgreen,\n  name = \"Target (upright)\",\n  points([0], [0]),\n  title = \"Phase Portrait: Swing-Up\",\n  xlabel = \"theta (deg)\",\n  ylabel = \"omega (deg/s)\",\n  grid = true\n)$",
