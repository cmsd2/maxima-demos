er\",\"mode\":\"markers\",\"marker\":{\"color\":\"tomato\",\"size\":10},\"name\":\"Start (hanging)\"},{\"x\":[0.0],\"y\":[0.0],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"forestgreen\",\"size\":10},\"name\":\"Target (upright)\"}],\"layout\":{\"title\":{\"text\":\"Phase Portrait: Swing-Up (u_max = 12)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"theta (deg)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"omega (deg/s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "### Still not upright — why?\n\nThe torque limit is no longer the bottleneck ($u_{\\max} = 12 > mgl = 9.81$), yet the pendulum settles at $\\theta^* \\approx 28°$. The problem is the **policy structure**.\n\nNear upright ($\\theta \\approx 0$), $\\cos\\theta \\approx 1$, so the policy becomes:\n\n$$u \\approx w_1\\theta + w_2 + w_3\\omega$$\n\nThe $w_2$ term is a **constant bias** that shifts the equilibrium away from $\\theta = 0$. Setting $w_2 = 0$ would fix the equilibrium, but then the policy has no mechanism to initiate the swing from hanging ($\\theta = \\pi$). A linear policy in $[\\sin\\theta, \\cos\\theta, \\omega]$ cannot express both \"push hard when hanging\" and \"stop pushing at upright.\"",
      "metadata": {}
    },
    {
      "cell_type": "markdown",
      "source": "## 6. Better Features\n\nReplace $\\cos\\theta$ with $1 - \\cos\\theta$ in the feature vector:\n\n$$u = \\text{clip}(w_1 \\sin\\theta + w_2 (1 - \\cos\\theta) + w_3 \\omega,\\; -u_{\\max},\\; u_{\\max})$$\n\nThis feature is 0 at upright and 2 at hanging, so it provides swing-up torque that **vanishes at the target**. Near upright: $u \\approx w_1 \\theta + w_2 \\theta^2/2 + w_3 \\omega$, which has its equilibrium at $\\theta = 0$.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Cost function with improved features: [sin(theta), 1-cos(theta), omega] */\nsimulate_cost3(w1v, w2v, w3v) := block(\n  [u_expr, rhs1, rhs2, tspan_sim, traj, th_col, om_col, cost_state, n_t],\n  u_expr : max(-u_max, min(u_max,\n    w1v * sin(theta) + w2v * (1 - cos(theta)) + w3v * omega)),\n  rhs1 : omega,\n  rhs2 : -(gv/lp)*sin(theta) - bp*omega + u_expr/(mp*lp^2),\n  tspan_sim : np_linspace(0, 6, 300),\n  traj : np_cvode([rhs1, rhs2], [t, theta, omega],\n                  [float(%pi), 0.0], tspan_sim, 1e-8, 1e-8),\n  th_col : np_slice(traj, all, 1),\n  om_col : np_slice(traj, all, 2),\n  cost_state : np_add(\n    np_pow(np_sub(1.0, np_cos(th_col)), 2),\n    np_scale(0.1, np_pow(om_col, 2))),\n  n_t : first(np_shape(traj)),\n  float(np_mean(cost_state) + 2.0 * np_ref(cost_state, n_t - 1))\n)$\n\ncem_cost3(w) := simulate_cost3(np_ref(w, 0), np_ref(w, 1), np_ref(w, 2))$\n\nnp_seed(42)$\n[best_w3, cost_history3] : np_cem(cem_cost3, 3,\n  n_samples=50, n_elites=10, n_gens=50, sigma0=5.0, sigma_min=0.3)$\n\ncem_mu3 : np_to_list(best_w3)$\nprint(\"Improved policy: w =\",\n  map(lambda([x], float(round(x * 100) / 100)), cem_mu3))$\nprint(\"Final cost:\", last(np_to_list(cost_history3)))$",
      "metadata": {},
      "execution_count": 69,
      "outputs": [
