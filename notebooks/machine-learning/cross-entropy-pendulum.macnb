98814516,3.5522048692636936,2.6199099196970055,1.6811751395295242,0.7389925603641277,-0.20364469528303494,-1.143749730440302,-2.078349268091734,-3.004490685878113,-3.9192494861822214,-4.8197363086399285,-5.703104262070961,-6.566556206768977,-7.40735187570683,-8.222815400612092,-9.010342446917667,-9.767407701221153,-10.491572230804454,-11.180490844922865,-11.83191949875927,-12.443722703964433,-13.013880631276583,-13.540496591184954,-14.021803804934368,-14.456172501472164,-14.84211664842402,-15.178300040070964,-15.463543042211999,-15.69682761398676,-15.8773033854404,-16.004292094551392,-16.07729208677504,-16.095982502929893,-16.060225779100854,-15.970071156188885,-15.825755707368103,-15.627706103029201,-15.376538776706703,-15.073059365339367,-14.718261952567744,-14.313326405979254,-13.859616042971911],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"royalblue\",\"width\":2},\"name\":\"Trajectory\"},{\"x\":[180.0],\"y\":[0.0],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"tomato\",\"size\":10},\"name\":\"Start (hanging)\"},{\"x\":[0.0],\"y\":[0.0],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"forestgreen\",\"size\":10},\"name\":\"Target (upright)\"}],\"layout\":{\"title\":{\"text\":\"Phase Portrait: Swing-Up\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"theta (deg)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"omega (deg/s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
