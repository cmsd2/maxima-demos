981,138.07477125895966,137.5224729117971,136.97238375507177,136.42449495203365,135.87879770127978,135.3352832366127],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"gray\",\"width\":2,\"dash\":\"dash\"},\"name\":\"True decay\"}],\"layout\":{\"title\":{\"text\":\"Radioactive Decay: Parameter Recovery\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Time\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Count N(t)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
