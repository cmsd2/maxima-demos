23,-0.15988573815657312,-0.1537242374081212,-0.14742241829482042,-0.1409883881381709,-0.1344303581092235,-0.1277566331382846,-0.12097560177700378,-0.11409572602480503,-0.10712553113161041,-0.10007359538875615],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"gray\",\"width\":2,\"dash\":\"dash\"},\"name\":\"True model\"}],\"layout\":{\"title\":{\"text\":\"Inverse Problem: Recovered Parameters\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Time (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Position x(t)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
