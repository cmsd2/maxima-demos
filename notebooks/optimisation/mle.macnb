6362,-0.37778077409259536,0.9786150139113592,3.5110359070429173,2.3975992868679152,5.2275259801533895,-0.10705818549570445,1.558683543359381,4.25897986913884,1.110992226162086,3.687649576132275,-1.517929388453581,4.088350400337613,1.264223498702423,5.78007127283334,2.005148128874126,2.8846242967131634,3.5289537343568878,3.400887208215768,4.798331388118111,1.5131728070996444,1.7275070127631182,6.249089288831005,2.4066725893053484,1.305158072911234,3.487864557619098,1.7217048105714121,5.926631474262253,1.0657011710478737,3.2649984815542306,6.2533111712961915,2.5403126012108994,0.9594520287788031,1.4689716776845338,5.363252584891143,1.5768309368785491,0.9919714160770878,1.3417373966332187,2.326865671349963,0.3984248653354574,3.9821769865466154,3.2408025800194538,-0.14215767814359292,3.1855854744759804,2.1940086691235035,1.8863621455147424,4.403610168440414,7.492624257630407,5.045313376709227,0.23267951253542885,3.795552711370589,-0.24171909645744405,2.7008141921500943,1.121535960553689,2.2244878975890447,5.227725606811707,2.798567660699934,1.9428287073920776,1.6457103120942527,3.388721514115563,0.3425017011644811,-0.6208420970394952,3.6027186597947027,2.545096161397863,2.450589342985179,4.832617916575786,2.3958197065220856,4.088325504230324,0.8152938078892986,6.658008050206661,1.634806701398216,4.6196514836886164,6.842522701256957,-1.0048277129632401,3.58404817539059,4.345289398549751,-1.7035451494067857,2.8920506525582064,7.7271488777391335,-0.809947065296905,2.3396582152709264,2.5092866837237797,4.527609556914643,0.25661551780105496,2.3601016564457318,-0.4367024749118995,2.663499818330775,2.697727386368665,4.1569151748696855,3.7503405146120263,2.00078806619187,5.490079620796884,3.146448035778196,6.384798934094,4.342006907019852],\"type\":\"histogram\",\"marker\":{\"color\":\"steelblue\"},\"name\":\"histogram\"}],\"layout\":{\"title\":{\"text\":\"Normal MLE: Histogram of Data\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Count\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
