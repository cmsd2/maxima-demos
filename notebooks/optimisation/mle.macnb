.1743646754753727,1.148534069834654,0.9972966373991304,0.9703206704701246,0.7546800420892299,2.071866803644972,2.522472517477353,0.8420460160423849,2.007554726023602,1.369599749153969,0.8437015383925724,1.793554726480645,0.26723044133532325,1.0788786863648305,2.772975385345724,0.7379945831565011,0.7456502827167829,1.6127712507507244,0.8575277061912413,0.9538495309989574,1.4518473852985578,1.8043775128752824,2.5921904465943397,1.3670393675084958,1.5359010764937495,0.4582857177667276,1.933146197583877,0.4414699649111574,2.2366944891832734,3.1673226397632113,2.31234837418274,1.7785346217805706,0.5616211824671846,0.7830283831602607,2.033322606528481,0.2848454714520877,2.2159800343899634,0.9489872185314001,1.4695708567042138,2.7874525577594502,2.3637794113916026,2.4911307318964533,1.1275543005515563,3.05477757706867,1.8510085714705258,1.4675076861741752,1.9406633240381579,0.9878289927466272,2.2810238463612404,1.4823515840021355,1.4424148672509205,1.1845222887146876,0.8391413104112191,0.6282114935777816,2.712236168829706,3.0572376024675165,2.1236202876487456,1.8137883473166228,2.6523615238690006,1.4164440848154665,0.8684859441304904,0.824252882183758,2.6969097727761477,0.5776183506941439,2.9974590123217943,2.1997006335703224,2.1484583436105016,1.498687094442531,1.099115979843407,3.6149631149070793,1.3918602596169094,2.2156186385329937,0.7538535590269094,1.5407026926855296,0.16304352952704393,1.0485698319912296,0.6111010516046684,0.5554868796626472,1.3073352098881135,1.860263328282794,1.885881576613212,0.6131876813858876,1.2963761184283555,3.2199838814745023,1.8839645711248234,2.594400106514324,2.319754317890259,1.2615071512164773,0.9886265327384779],\"type\":\"histogram\",\"marker\":{\"color\":\"steelblue\"},\"name\":\"histogram\"}],\"layout\":{\"title\":{\"text\":\"Gamma MLE: Histogram of Data\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Count\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## 3. Fisher Information and Confidence Intervals [S+N]\n\nThe **Fisher information** per observation is the negative expected Hessian of the log-likelihood:\n$$\\mathcal{I}(\\theta)_{jk} = -E\\!\\left[\\frac{\\partial^2 \\ell_i}{\\partial \\theta_j \\partial \\theta_k}\\right]$$\n\nFor the Normal case, we derive it symbolically from the log-likelihood in Section 1.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Hessian of per-observation log-likelihood */\nH_11 : diff(ll_i(mu, sigma, x[i]), mu, 2);\nH_12 : diff(diff(ll_i(mu, sigma, x[i]), mu), sigma);\nH_22 : diff(ll_i(mu, sigma, x[i]), sigma, 2);",
      "metadata": {},
      "execution_count": 21,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "-(1/sigma^2)\n-((2*(x[i]-mu))/sigma^3)"
          ]
        },
        {
          "data": {
            "text/latex": [
              "{{1}\\over{\\sigma^2}}-{{3\\,\\left(x_{i}-\\mu\\right)^2}\\over{\\sigma^4}}"
            ]
          },
          "execution_count": 21,
          "metadata": {},
          "output_type": "execute_result"
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Fisher information: -E[H]\n   Using E[(x-mu)^2] = sigma^2, E[x-mu] = 0 */\nI_11 : ratsimp(-subst([(x[i] - mu)^2 = sigma^2, x[i] - mu = 0], H_11));\nI_22 : ratsimp(-subst([(x[i] - mu)^2 = sigma^2, x[i] - mu = 0], H_22));\nprint(\"Fisher information per observation:\")$\nprint(\"  I_11 =\", I_11, \", I_22 =\", I_22)$\n\n/* Standard errors: se = 1/sqrt(n * I_jj) */\nse_mu : 1 / sqrt(n_norm * float(subst(sigma = sigma_cf, I_11)))$\nse_sigma : 1 / sqrt(n_norm * float(subst(sigma = sigma_cf, ratsimp(I_22))))$\nprint(\"95% CI for mu:\", mu_cf, \"+/-\", 1.96*se_mu)$\nprint(\"95% CI for sigma:\", sigma_cf, \"+/-\", 1.96*se_sigma)$",
      "metadata": {},
      "execution_count": 22,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "1/sigma^2\n2/sigma^2\nFisher information per observation:\n  I_11 = 1/sigma^2 , I_22 = 2/sigma^2\n95%o166 CI for mu: 2.780627013714442 +/- 0.28973366586664173\n95%o166 CI for sigma: 2.0905371415544867 +/- 0.2048726398723397"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## 4. Logistic Regression as MLE [S+N]\n\nLogistic regression is a GLM where the likelihood for binary $y_i \\in \\{0,1\\}$ is\n$$\\ell(\\mathbf{w}) = \\sum_{i=1}^n \\bigl[ y_i \\ln\\sigma(\\mathbf{w}^T\\mathbf{x}_i) + (1-y_i)\\ln(1 - \\sigma(\\mathbf{w}^T\\mathbf{x}_i)) \\bigr]$$\n\nwhere $\\sigma(z) = 1/(1+e^{-z})$ is the sigmoid. The gradient simplifies beautifully:",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Sigmoid and its derivative */\nsigmoid_sym(z) := 1 / (1 + exp(-z))$\nratsimp(diff(sigmoid_sym(z), z));",
      "metadata": {},
      "execution_count": 23,
      "outputs": [
        {
          "data": {
            "text/latex": [
              "{{e^{z}}\\over{e^{2\\,z}+2\\,e^{z}+1}}"
            ]
          },
          "execution_count": 23,
          "metadata": {},
          "output_type": "execute_result"
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Generate 2D classification data */\nn_lr : 100$\nx1_lr : np_randn([n_lr])$\nx2_lr : np_randn([n_lr])$\n\n/* True boundary: 1 + 2*x1 - 1.5*x2 > 0 */\nz_true : np_add(1.0, np_add(np_scale(2.0, x1_lr), np_scale(-1.5, x2_lr)))$\ny_lr : np_map(lambda([v], if v > 0 then 1.0 else 0.0), z_true)$\n\n/* Design matrix: [1, x1, x2] */\nX_lr : np_hstack(np_ones([n_lr, 1]),\n                 np_reshape(x1_lr, [n_lr, 1]),\n                 np_reshape(x2_lr, [n_lr, 1]))$\ny_lr_col : np_reshape(y_lr, [n_lr, 1])$\n\n/* Numerically stable sigmoid: clip input to avoid exp overflow */\nnp_sigmoid(z) := np_div(1.0, np_add(1.0, np_exp(np_neg(np_clip(z, -500.0, 500.0)))))$\n\n/* Negative log-likelihood */\nlr_nll(w) := block([z, p, p_safe],\n  z : np_matmul(X_lr, w),\n  p : np_sigmoid(z),\n  p_safe : np_clip(p, 1.0e-10, 1.0 - 1.0e-10),\n  -np_mean(np_add(\n    np_mul(y_lr_col, np_log(p_safe)),\n    np_mul(np_sub(1.0, y_lr_col),\n           np_log(np_sub(1.0, p_safe))))))$\n\nlr_grad(w) := block([z, p],\n  z : np_matmul(X_lr, w),\n  p : np_sigmoid(z),\n  np_scale(1.0 / n_lr,\n    np_matmul(np_transpose(X_lr), np_sub(p, y_lr_col))))$\n\n[w_lr, nll_lr, conv_lr] : np_minimize(lr_nll, lr_grad, np_zeros([3, 1]))$\nprint(\"Fitted w =\", np_to_list(np_flatten(w_lr)))$\nprint(\"True:  w = [1, 2, -1.5]\")$",
      "metadata": {},
      "execution_count": 24,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "*************************************************\n  N=    3   NUMBER OF CORRECTIONS= 3\n       INITIAL VALUES\n F=  6.931471805599458D-01   GNORM=  3.761164029443863D-01\n*************************************************\n   I  NFN     FUNC                    GNORM                   STEPLENGTH\n   1    2     4.210458639576212D-01   1.863708524500784D-01   2.658751365725103D+00\n  28   32     6.102377849729093D-05   1.351944840873941D-05   1.000000000000000D+00\n THE MINIMIZATION TERMINATED WITHOUT DETECTING ERRORS.\n IFLAG = 0\nFitted w = [994.9408636632331,2000.2701547726429,-1504.0625752993801]\nTrue:  w = [1, 2, -1.5]"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Decision boundary: w0 + w1*x1 + w2*x2 = 0  =>  x2 = -(w0 + w1*x1)/w2 */\nw0 : np_ref(w_lr, 0, 0)$  w1 : np_ref(w_lr, 1, 0)$  w2 : np_ref(w_lr, 2, 0)$\n\n/* Separate classes using boolean mask + extract */\nmask_pos : np_greater(y_lr, 0.5)$\nmask_neg : np_logical_not(mask_pos)$\n\nax_draw2d(\n  color=\"blue\", marker_size=5, name=\"Class 1\",\n  points(np_to_list(np_extract(mask_pos, x1_lr)),\n         np_to_list(np_extract(mask_pos, x2_lr))),\n  color=\"red\", marker_size=5, name=\"Class 0\",\n  points(np_to_list(np_extract(mask_neg, x1_lr)),\n         np_to_list(np_extract(mask_neg, x2_lr))),\n  color=\"black\", line_width=2, name=\"Decision boundary\",\n  explicit(-(w0 + w1*u) / w2, u, -3, 3),\n  title=\"Logistic Regression MLE\",\n  xlabel=\"x1\", ylabel=\"x2\", grid=true, showlegend=true\n)$",
      "metadata": {},
      "execution_count": 25,
      "outputs": [
        {
          "data": {
            "application/x-maxima-plotly": [
