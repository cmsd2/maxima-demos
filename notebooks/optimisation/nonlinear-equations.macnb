22572508778384,4.831278383976964,4.8399999753234795,4.8487373111892635,4.857490419996871,4.8662593302201635,4.875044070384402,4.883844669066349,4.8926611548943475,4.901493556548426,4.910341902760388,4.919206222313899],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"gray\",\"width\":2,\"dash\":\"dash\"},\"name\":\"True curve\"}],\"layout\":{\"title\":{\"text\":\"Nonlinear Least Squares Fit\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
