,0.435420150381503,0.43281024722776335,0.4302159878021925,0.4276372783364721,0.42507402562432905,0.4225261370181685,0.4199935204257233,0.4174760843067265,0.41497373766960305,0.41248639006817917,0.410013951598415,0.40755633289515475,0.4051134451288956,0.4026852000025782,0.4002715097483945,0.39787228712461564,0.39548744541243874,0.3931168984128522,0.39076056044352026,0.38841834633568656,0.3860901714310944,0.3837759515789286,0.38147560313277235,0.37918904294758404,0.37691618837669355,0.37465695726881304,0.37241126796506874,0.3701790392960496,0.3679601905788722,0.3657546416142664,0.36356231268367467,0.36138312454637167,0.3592169984366005,0.3570638560607247,0.3549236195943992,0.3527962116797575,0.35068155542261426,0.3485795743896881,0.3464901926058369,0.3444133345513128,0.3423489251590329,0.3402968898118652,0.3382571543399315,0.3362296450179276,0.3342142885624578,0.3322110121293854,0.33021974331120174,0.32824041013440697,0.3262729410569102,0.3243172649654425,0.3223733111729872,0.3204410094162249,0.3185202898529935,0.3166110830597638,0.314713320029131,0.31282693216731905,0.31095185129170305,0.3090880096283433,0.3072353398095363,0.3053937748713805,0.30356324825135395,0.3017436937859105,0.2999350457080875,0.2981372386451282,0.29635020761611996,0.29457388802964457,0.2928082156814441,0.29105312675210004,0.2893085578047269,0.28757444578267893,0.2858507280072715,0.2841373421755149,0.282434226357863,0.2807413189959746,0.27905855890048825,0.27738588524881114,0.27572323758292006,0.2740705558071765,0.27242778018615477,0.2707948513424822,0.2691717102546938,0.2675582982550983,0.2659545570276576,0.26436042860587977,0.262775855370723,0.2612007800485133,0.25963514570887475,0.2580788957626708,0.25653197395996036,0.254994324387963,0.253465891469039,0.2519466199586808,0.2504364549435154,0.24893534183931973],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"black\",\"width\":2,\"dash\":\"dash\"},\"name\":\"True\"}],\"layout\":{\"title\":{\"text\":\"Linearized vs Nonlinear Fit\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
