99165137082673,14.16266742166734,13.333022695462356,12.502754771949109,11.671901392151236,10.840500458378603,10.00859003422776,9.176208344581557,8.34339377560938,7.51018487476684,6.676620350796307,5.84273907372623,5.008580074871588,4.174182546833966,3.3395858435011023,2.5048294800473436,1.669953132933415,0.8349966399064215,0.0],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"blue\",\"width\":2},\"name\":\"Exact\"},{\"x\":[0.47619047619047616,0.9523809523809523,1.4285714285714284,1.9047619047619047,2.380952380952381,2.8571428571428568,3.333333333333333,3.8095238095238093,4.285714285714286,4.761904761904762,5.238095238095238,5.7142857142857135,6.19047619047619,6.666666666666666,7.142857142857142,7.619047619047619,8.095238095238095,8.571428571428571,9.047619047619047,9.523809523809524],\"y\":[19.796278299677777,39.07836755261071,57.38349761672844,74.30031725463512,89.46889413360933,102.58071482560412,113.37868480724698,121.65712845983995,127.2617890693596,130.08982882645688,130.08982882645722,127.26178906936057,121.65712845984145,113.3786848072488,102.58071482560615,89.46889413361146,74.30031725463718,57.38349761673022,39.078367552612,19.796278299678452],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"red\",\"size\":5},\"name\":\"FD (n=20)\"}],\"layout\":{\"title\":{\"text\":\"Beam Deflection: Exact vs Finite Difference\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Position x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Deflection y\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
