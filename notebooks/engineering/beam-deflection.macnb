99165137082673,14.16266742166734,13.333022695462356,12.502754771949109,11.671901392151236,10.840500458378603,10.00859003422776,9.176208344581557,8.34339377560938,7.51018487476684,6.676620350796307,5.84273907372623,5.008580074871588,4.174182546833966,3.3395858435011023,2.5048294800473436,1.669953132933415,0.8349966399064215,0.0],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"blue\",\"width\":2},\"name\":\"Exact\"},{\"x\":[0.47619047619047616,0.9523809523809523,1.4285714285714284,1.9047619047619047,2.380952380952381,2.8571428571428568,3.333333333333333,3.8095238095238093,4.285714285714286,4.761904761904762,5.238095238095238,5.7142857142857135,6.19047619047619,6.666666666666666,7.142857142857142,7.619047619047619,8.095238095238095,8.571428571428571,9.047619047619047,9.523809523809524],\"y\":[19.796278299677777,39.07836755261071,57.38349761672844,74.30031725463512,89.46889413360933,102.58071482560412,113.37868480724698,121.65712845983995,127.2617890693596,130.08982882645688,130.08982882645722,127.26178906936057,121.65712845984145,113.3786848072488,102.58071482560615,89.46889413361146,74.30031725463718,57.38349761673022,39.078367552612,19.796278299678452],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"red\",\"size\":5},\"name\":\"FD (n=20)\"}],\"layout\":{\"title\":{\"text\":\"Beam Deflection: Exact vs Finite Difference\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Position x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Deflection y\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## Convergence Study\n\nAs we refine the mesh (increase $n$), the finite difference error should decrease. For the central difference stencil of the 4th derivative, we expect the truncation error to scale as $O(h^2)$, which we verify by computing the midpoint error for several values of $n$.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Convergence study: solve for several mesh sizes */\nnn_list : [5, 10, 20, 40, 80]$\nerr_list : []$\nhh_list : []$\n\nfor nn in nn_list do block([hh, KK, ff, yy, mid_idx, y_mid_fd, err],\n  hh : float(subst(params, L) / (nn + 1)),\n  /* Build stiffness matrix */\n  KK : np_zeros([nn, nn]),\n  for i : 0 thru nn - 1 do (\n    for k : -2 thru 2 do block([j : i + k],\n      if j >= 0 and j < nn then\n        np_set(KK, i, j, np_ref(KK, i, j) + coeffs[k + 3] / hh^4)\n    )\n  ),\n  /* Apply moment BCs: ghost points from y''(0)=0 and y''(L)=0 */\n  np_set(KK, 0, 0, np_ref(KK, 0, 0) - 1/hh^4),\n  np_set(KK, nn-1, nn-1, np_ref(KK, nn-1, nn-1) - 1/hh^4),\n  ff : np_full([nn, 1], float(subst(params, w0/EI))),\n  yy : np_solve(KK, ff),\n  /* Midpoint index (closest to L/2) */\n  mid_idx : round(nn / 2) - 1,\n  y_mid_fd : np_ref(yy, mid_idx, 0),\n  err : abs(y_mid_fd - y_mid_exact),\n  hh_list : endcons(hh, hh_list),\n  err_list : endcons(err, err_list),\n  print(\"n =\", nn, \", h =\", hh, \", midpoint error =\", err)\n)$",
      "metadata": {},
      "execution_count": 9,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "n = 5 , h = 1.6666666666666667 , midpoint error = 14.467592592593562\nn = 10 , h = 0.9090909090909091 , midpoint error = 0.43577681396661205\nn = 20 , h = 0.47619047619047616 , midpoint error = 0.1185045068764623\nn = 40 , h = 0.24390243902439024 , midpoint error = 0.031011187625580305\nn = 80 , h = 0.12345679012345678 , midpoint error = 0.007940162648679916"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Plot convergence (log-log) */\nlog_h : makelist(log(hh_list[i]) / log(10), i, 1, length(hh_list))$\nlog_err : makelist(log(max(err_list[i], 1e-16)) / log(10), i, 1, length(err_list))$\n\n/* Estimate convergence rate from last two points */\nrate : (last(log_err) - log_err[length(log_err)-1])\n      / (last(log_h) - log_h[length(log_h)-1])$\nprint(\"Estimated convergence rate (slope):\", rate)$\n\nax_draw2d(\n  color=\"blue\", line_width=2, marker_size=6,\n  name=\"FD error\",\n  lines(log_h, log_err),\n  points(log_h, log_err),\n  color=\"gray\", line_width=1, name=\"O(h^2) reference\",\n  explicit(2*x + log_err[1] - 2*log_h[1], x,\n           log_h[1] - 0.2, last(log_h) + 0.2),\n  title=\"Convergence: log(error) vs log(h)\",\n  xlabel=\"log10(h)\", ylabel=\"log10(error)\",\n  grid=true, showlegend=true\n)$",
      "metadata": {},
      "execution_count": 10,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Estimated convergence rate (slope): 2.00096947721274"
          ]
        },
