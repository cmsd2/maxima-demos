99165137082673,14.16266742166734,13.333022695462356,12.502754771949109,11.671901392151236,10.840500458378603,10.00859003422776,9.176208344581557,8.34339377560938,7.51018487476684,6.676620350796307,5.84273907372623,5.008580074871588,4.174182546833966,3.3395858435011023,2.5048294800473436,1.669953132933415,0.8349966399064215,0.0],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"blue\",\"width\":2},\"name\":\"Exact deflection\"}],\"layout\":{\"title\":{\"text\":\"Simply Supported Beam u2014 Exact Solution\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Position x\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Deflection y\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": "## Finite Difference Method\n\nWe discretise the 4th derivative using the central difference stencil:\n\n$$y''''(x_i) \\approx \\frac{y_{i-2} - 4y_{i-1} + 6y_i - 4y_{i+1} + y_{i+2}}{h^4}$$\n\nFor $n$ interior points on the interval $[0, L]$ with spacing $h = L/(n+1)$, this produces an $n \\times n$ pentadiagonal linear system $K\\mathbf{y} = \\mathbf{f}$. The displacement BCs $y_0 = y_{n+1} = 0$ are absorbed by dropping those columns. The moment BCs $y''(0) = 0$ and $y''(L) = 0$ introduce ghost points $y_{-1}$ and $y_{n+2}$; since $y''(0) \\approx (y_{-1} - 2y_0 + y_1)/h^2 = 0$ with $y_0 = 0$, we get $y_{-1} = -y_1$, and similarly $y_{n+2} = -y_n$. Substituting these into the stencil modifies the first and last diagonal entries from $6/h^4$ to $5/h^4$.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* 4th derivative central difference stencil:              */\n/* y''''(x_i) ~ (y_{i-2} - 4*y_{i-1} + 6*y_i              */\n/*               - 4*y_{i+1} + y_{i+2}) / h^4              */\n/* For n interior points, this gives an (n x n) system     */\n\n/* Display the stencil symbolically */\nstencil : (y[i-2] - 4*y[i-1] + 6*y[i] - 4*y[i+1] + y[i+2]) / h^4;\nprint(\"FD stencil for y'''':\", stencil)$",
      "metadata": {},
      "execution_count": 53,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "(y[i+2]-4*y[i+1]+6*y[i]-4*y[i-1]+y[i-2])/h^4\nFD stencil for y'''': (y[i+2]-4*y[i+1]+6*y[i]-4*y[i-1]+y[i-2])/h^4"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Build the pentadiagonal stiffness matrix K */\nn : 20$  /* interior points */\nh_val : float(subst(params, L) / (n + 1))$\nprint(\"Grid spacing h =\", h_val)$\n\nK : np_zeros([n, n])$\ncoeffs : [1, -4, 6, -4, 1]$\nfor i : 0 thru n - 1 do (\n  for k : -2 thru 2 do block([j : i + k],\n    if j >= 0 and j < n then\n      np_set(K, i, j, np_ref(K, i, j) + coeffs[k + 3] / h_val^4)\n  )\n)$\n\n/* Apply moment BCs: y''(0)=0 gives y_{-1} = -y_1 (ghost point) */\n/* y''(L)=0 gives y_{n+2} = -y_n (ghost point)                  */\n/* Each adds -1/h^4 to the corresponding diagonal entry          */\nnp_set(K, 0, 0, np_ref(K, 0, 0) - 1/h_val^4)$\nnp_set(K, n-1, n-1, np_ref(K, n-1, n-1) - 1/h_val^4)$\n\nprint(\"Stiffness matrix K: shape\", np_shape(K))$",
      "metadata": {},
      "execution_count": 54,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Grid spacing h = 0.47619047619047616\nStiffness matrix K: shape [20,20]"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Build the RHS force vector and solve */\n/* RHS: w0/EI at each interior point */\nf : np_full([n, 1], float(subst(params, w0/EI)))$\n\n/* Solve K * y = f */\ny_fd : np_solve(K, f)$\nprint(\"FD solution computed, shape:\", np_shape(y_fd))$\nprint(\"Max deflection (FD):\", np_max(y_fd))$\n\n/* Compare to exact midpoint deflection */\ny_mid_exact : float(subst(append(params, [x=5]), y_exact))$\nprint(\"Exact midpoint deflection:\", y_mid_exact)$",
      "metadata": {},
      "execution_count": 55,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "FD solution computed, shape: [20,1]\nMax deflection (FD): 130.08982882645722\nExact midpoint deflection: 130.20833333333334"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Plot FD solution vs exact solution */\nx_fd : makelist(float(i * h_val), i, 1, n)$\ny_fd_list : np_to_list(np_col(y_fd, 0))$\n\nax_draw2d(\n  color=\"blue\", line_width=2, name=\"Exact\",\n  explicit(subst(params, y_exact), x, 0, 10),\n  color=\"red\", marker_size=5, name=\"FD (n=20)\",\n  points(x_fd, y_fd_list),\n  title=\"Beam Deflection: Exact vs Finite Difference\",\n  xlabel=\"Position x\", ylabel=\"Deflection y\",\n  grid=true, showlegend=true\n)$",
      "metadata": {},
      "execution_count": 56,
      "outputs": [
        {
          "data": {
