2172814011798,1.0080461633425755,1.0078768371278615,1.00770930080443,1.0075435521039207,1.0073795884489227,1.0072174069596045,1.0070570044602725,1.0068983774858586,1.0067415222883358,1.0065864348430633,1.0064331108550613,1.006281545765214,1.0061317347564025,1.0059836727595686,1.0058373544597055,1.0056927743017814,1.0055499264965926,1.0054088050265455,1.0052694036513716,1.0051317159137723,1.004995735144994,1.0048614544703374,1.0047288668145948],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"red\",\"width\":2},\"name\":\"v_C(t) — voltage\"}],\"layout\":{\"title\":{\"text\":\"Step Response of RLC Circuit\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Time (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Amplitude\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
