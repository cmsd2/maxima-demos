      "cell_type": "code",
      "source": "/* Phase portrait: theta vs theta_dot */\nax_draw2d(\n  line_width = 2,\n  color = royalblue,\n  name = \"Trajectory\",\n  lines(th_deg, map(lambda([a], a * 180 / float(%pi)), thd_col)),\n  marker_size = 8,\n  color = forestgreen,\n  name = \"Start\",\n  points([th_deg[1]], [0]),\n  color = tomato,\n  name = \"End\",\n  points([last(th_deg)], [last(thd_col) * 180 / float(%pi)]),\n  title = \"Phase Portrait (theta vs theta-dot)\",\n  xlabel = \"theta (deg)\",\n  ylabel = \"theta-dot (deg/s)\",\n  grid = true\n)$",
