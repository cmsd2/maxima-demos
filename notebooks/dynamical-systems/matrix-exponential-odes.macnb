19886435394e-4,1.0549438603102768e-4,1.003493641123507e-4,9.545526787360406e-5,9.079985952496953e-5],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"green\",\"width\":2},\"name\":\"y(t)\"}],\"layout\":{\"title\":{\"text\":\"3D System: Component Time Series\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"value\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
