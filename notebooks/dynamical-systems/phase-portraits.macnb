    },
    {
      "cell_type": "markdown",
      "source": "## Nonlinear Example: Lotka-Volterra [S+N]\n\nThe classical predator-prey model:\n\n$$\\dot{x} = x(1-y) \\qquad \\dot{y} = y(x-1)$$\n\nwhere $x$ is the prey population and $y$ is the predator population. We use Maxima's symbolic tools to compute the Jacobian, find fixed points, and classify their stability.",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "/* Lotka-Volterra system */\nf1 : x*(1 - y)$\nf2 : y*(x - 1)$\n\n/* Compute the Jacobian symbolically */\nJ_lv : matrix(\n  [diff(f1, x), diff(f1, y)],\n  [diff(f2, x), diff(f2, y)]\n);\n\nprint(\"Jacobian:\")$\nJ_lv;",
      "metadata": {},
      "execution_count": 117,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "matrix([1-y,-x],[y,x-1])\nJacobian:"
          ]
        },
        {
          "data": {
            "text/latex": [
              "\\ifx\\endpmatrix\\undefined\\pmatrix{\\else\\begin{pmatrix}\\fi 1-y&-x\\cr y&x-1\\cr \\ifx\\endpmatrix\\undefined}\\else\\end{pmatrix}\\fi "
            ]
          },
          "execution_count": 117,
          "metadata": {},
          "output_type": "execute_result"
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Find fixed points */\nfps_lv : solve([f1 = 0, f2 = 0], [x, y]);\n\nprint(\"Fixed points:\")$\nfor fp in fps_lv do print(fp)$",
      "metadata": {},
      "execution_count": 118,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "[[x = 0,y = 0],[x = 1,y = 1]]\nFixed points:\n[x = 0,y = 0]\n[x = 1,y = 1]"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Classify each fixed point via eigenvalues of the Jacobian */\nfor fp in fps_lv do block(\n  [J_fp, evals],\n  J_fp : subst(fp, J_lv),\n  evals : eigenvalues(J_fp),\n  print(\"--- Fixed point:\", fp, \"---\"),\n  print(\"  J =\", J_fp),\n  print(\"  Eigenvalues =\", evals[1]),\n  if every(lambda([e], is(float(realpart(e)) < 0)), evals[1]) then\n    print(\"  Classification: STABLE\")\n  elseif every(lambda([e], is(float(realpart(e)) > 0)), evals[1]) then\n    print(\"  Classification: UNSTABLE\")\n  elseif every(lambda([e], is(float(realpart(e)) = 0)), evals[1]) then\n    print(\"  Classification: CENTRE\")\n  else\n    print(\"  Classification: SADDLE\")\n)$",
      "metadata": {},
      "execution_count": 119,
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "--- Fixed point: [x = 0,y = 0] ---\n  J = matrix([1,0],[0,-1])\n  Eigenvalues = [-1,1]\n  Classification: SADDLE\n--- Fixed point: [x = 1,y = 1] ---\n  J = matrix([0,-1],[1,0])\n  Eigenvalues = [-%i,%i]\n  Classification: SADDLE"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": "/* Phase portrait of the Lotka-Volterra system */\nax_draw2d(\n  color=\"#cccccc\",\n  ax_vector_field(f1, f2, x, 0, 4, y, 0, 4),\n  color=\"#e41a1c\",\n  initial_points=[[0.5, 0.5], [1.0, 2.0], [2.0, 0.5],\n                  [0.5, 1.5], [3.0, 1.0], [1.5, 3.0]],\n  ax_streamline(f1, f2, x, 0, 4, y, 0, 4),\n  title=\"Lotka-Volterra Phase Portrait\",\n  xlabel=\"x (prey)\", ylabel=\"y (predator)\",\n  aspect_ratio=true\n)$",
      "metadata": {},
      "execution_count": 120,
      "outputs": [
        {
