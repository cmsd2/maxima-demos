2447766,-1.4940150341655765,-1.5674145867381901,-1.636896419529843,-1.702286864162934,-1.7634224785984778,-1.8201504556560375,-1.8723290049520536,-1.9198277073019208,-1.9625278406999918,-2.0003226770627287,-2.0331177489932992,-2.060831085900843,-2.083393418884236,-2.100748353868246,-2.1128525125593374,-2.1196756408687962,-2.121200684532188,-2.1174238317361276,-2.1083545226458256,-2.0940154258095895,-2.074442381499263,-2.049684312128217,-2.0198030999708054,-1.9848734324889188,-1.9449826156522443,-1.9002303557188287,-1.8507285100213826,-1.7966008073822297,-1.7379825388557166,-1.6750202195710686,-1.6078712225209058,-1.536703385210758,-1.4616945901527514,-1.3830323202520103,-1.3009131901970816,-1.2155424550256568,-1.1271334970939246,-1.035907292731861,-0.9420918599175434,-0.8459216883510116,-0.747637153352198,-0.6474839150478742,-0.5457123043493333,-0.4425766972555466],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"width\":2},\"showlegend\":false,\"hoverinfo\":\"skip\"}],\"layout\":{\"title\":{\"text\":\"Centre (Simple Harmonic Oscillator)\"},\"width\":700,\"height\":700,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"x\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"y\"},\"scaleanchor\":\"x\",\"scaleratio\":1,\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
