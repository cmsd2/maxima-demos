145,0.7130362349021224,-0.40649729279466484,-1.6059975010412284,-2.8854643898375656,-4.244897959183673,-5.68429820907955,-7.203665139525189,-8.80299875052061,-10.482299042065799,-12.241566014160762,-14.080799666805495,-15.999999999999988]],\"type\":\"surface\",\"name\":\"x^3-3*x*y^2\"}],\"layout\":{\"title\":{\"text\":\"Monkey Saddle\"},\"width\":700,\"height\":450,\"paper_bgcolor\":\"white\",\"scene\":{\"xaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"zaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}}"
            ]
          },
