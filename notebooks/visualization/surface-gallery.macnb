,0.007886400942508058,0.007653411959211545,0.007012387018671208,0.005967255674705086,0.0045580864200641166,0.002859477697575586,9.745879390326189e-4,-9.745879390326189e-4,-0.0028594776975755755,-0.004558086420064111,-0.005967255674705083,-0.0070123870186712045,-0.00765341195921154,-0.007886400942508061,-0.007740884914317069,-0.007273588632953313,-0.006559737899711656,-0.005683335404777467,-0.004727784330461755,-0.0037680064037041113,-0.0028648199402856412,-0.0020619003291177476,-0.001385225700112263,-8.445813607753037e-4,-4.3649673273391735e-4,-1.4792585930777343e-4,3.996143627404205e-5,1.4837186161978762e-4,1.9817945629030642e-4,2.0804993720369657e-4,1.9338240087825767e-4,1.6594635867465116e-4]],\"type\":\"surface\",\"name\":\"%e^((-y^2-x^2)/4)*cos(x)*sin(y)\"}],\"layout\":{\"title\":{\"text\":\"Gaussian-damped wave\"},\"width\":700,\"height\":450,\"paper_bgcolor\":\"white\",\"scene\":{\"xaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"zaxis\":{\"gridcolor\":\"#ddd\",\"linecolor\":\"black\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}}"
