0.8000000000706892,0.8000000000703095,0.8000000000699342,0.8000000000695632,0.8000000000691957,0.8000000000688317,0.8000000000684705,0.8000000000681121,0.8000000000677558,0.8000000000674017,0.8000000000670493,0.800000000066698,0.8000000000663477,0.8000000000659981],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"tomato\",\"width\":2},\"name\":\"Ang. momentum\"}],\"layout\":{\"title\":{\"text\":\"Conservation Laws (Elliptical Orbit)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Value\"},\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
