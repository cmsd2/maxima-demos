159,-0.7676872871187713,-0.6911856373316536,-0.6941652822540133,-0.6876612781209716,-0.638792057116142,-0.6095615131718648,-0.6570117890780465,-0.7315813461736288,-0.714932009353387,-0.5540395659422692,-0.3195236637994392,-0.11413783210961456,0.04725028003114637,0.2303590290202059,0.46242658362841316,0.6663082527056915,0.7416598628796697,0.6900281346007792,0.6193532453455595,0.619905413079918,0.6712556037151003,0.6969657794771814,0.6876050500108444,0.7235382663165093,0.8645941359034657,1.053637973497619,1.165841846663786,1.1445050310095555,1.0503176286319857,0.9649203626489675,0.8805535020481241,0.7228203198319018,0.4736725409072146,0.2260647816236252,0.09088488137897963,0.07284615050367707,0.07494230500471513,0.02348763764760148,-0.050751630682734764,-0.0785130884640729,-0.07115763254472665,-0.12802208755668318,-0.3164508349181394,-0.5803350966807418,-0.7984892283664581,-0.9187841464317159,-0.9960129915391136,-1.0902830253342572,-1.167196944669586,-1.1366777654748363,-0.9803315437359048,-0.796409872960337,-0.6977844185195755,-0.6915259147625041,-0.6929048905324384,-0.649813027793784,-0.6098981704243407,-0.6420511546785337,-0.7202527389865598,-0.7299953875544478,-0.5957591870654128,-0.3666448928717464,-0.15046632774948834,0.015633678156500214,0.1891721968517177,0.4145668981475952,0.6334618197196716,0.7388192464012955,0.7060386191908575,0.629281109914925,0.6134874043753717,0.6608725516934224,0.6959714576036307,0.6890563937176187,0.7084310447839502,0.828955363720358,1.018130805586067,1.15414087239232,1.1577638581269305,1.0702001835116564,0.9800809821579359,0.9009068565988542,0.7628179064964978,0.5275560664892387,0.269170564152756,0.10669206007708722,0.07115269323226973,0.0778570928526016],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"darkgreen\",\"width\":2},\"name\":\"Moving average (M=8)\"}],\"layout\":{\"title\":{\"text\":\"Time-Domain Smoothing via Convolution\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Time (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Amplitude\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
