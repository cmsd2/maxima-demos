    {
      "cell_type": "code",
      "source": "/* Magnitude spectrum of chirp */\nF_chirp : np_fft(chirp)$\nmag_chirp : np_abs(F_chirp)$\nhalf_N : N / 2$\n\nfreq_list : makelist(i * fs / N, i, 0, half_N)$\nmag_list : makelist(2 * np_ref(mag_chirp, i) / N, i, 0, half_N)$\n\nax_draw2d(\n  color=\"teal\", line_width=1.5,\n  lines(freq_list, mag_list),\n  title=\"Chirp Magnitude Spectrum\",\n  xlabel=\"Frequency (Hz)\", ylabel=\"Amplitude\",\n  grid=true\n)$",
      "metadata": {},
