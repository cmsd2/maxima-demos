161501182595627e-15,7.567753265760634e-16,5.929399650277356e-16,1.7816170548406293e-16,7.066731002956784e-16,1.9985317084017703e-16,6.915732004346402e-16,7.2231662139399925e-16,2.1259283747109402e-16,2.306426049420911e-16,2.0504105311628152e-16,3.7642523859754026e-16,3.752931036627306e-16,2.293580867698387e-16,1.3513050899647665e-16,4.475988766920464e-16,2.7390611965772135e-16,4.4316939433083934e-16,4.219767475746302e-17,2.636961907951689e-16,5.278941465120567e-16,5.343594022407967e-16,6.034524836701959e-16,4.591116917757066e-16,5.144823485913791e-16,2.1109352358396416e-16,2.092287626449423e-16,2.811048972476896e-16,3.527237293986878e-16,4.398921574390739e-16,3.892618955186474e-16,1.0008214892528982e-16,3.9860162582149126e-16,3.9080752761563945e-16,7.328166653430962e-16,4.767460994973849e-16,3.023040455499408e-16,7.727661070960008e-16,6.003621923358403e-16,6.57586631020712e-16,2.924012769148284e-16,1.2319977355483202e-16,5.118041777904954e-16,7.420349385781577e-16,2.497334632611438e-16,2.5460460629872926e-16,3.9608163433936594e-16,4.571631127683988e-16,1.3736946331792747e-15,6.7288291619743225e-16,7.672788299203313e-16,6.635268237457715e-16,3.7734819179262615e-16,8.494024484803007e-16,6.007659307929105e-16,1.3976389007122023e-16,5.095962184673236e-16,6.031865860187971e-16,1.095069886667919e-15,4.465894509949162e-16,4.161293896627566e-16,1.5238771765557716e-16,1.5400529075724785e-15,2.227151835706703e-15,1.221739466761407e-15,2.4581508637038926e-16,5.48125980869377e-16,7.576210919245871e-16,9.925698514190114e-16,2.235031041285983e-16],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"steelblue\",\"width\":1.5},\"name\":\"lines\"}],\"layout\":{\"title\":{\"text\":\"AM Spectrum (peaks at 35, 40, 45 Hz)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Frequency (Hz)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Amplitude\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
