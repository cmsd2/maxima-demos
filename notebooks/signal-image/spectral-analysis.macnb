7e-17,1.1599830834560692e-16,1.0679147274841294e-16,6.816678035548315e-17,4.7384278621925633e-17,2.0765652345572297e-16,1.111617795519769e-16,3.9310133950745993e-16,2.429973490694253e-16,3.460318385839682e-16,2.258135597116201e-16,1.1691440467142396e-16,3.6430980135918514e-16,2.9019895388109863e-16,1.6205815582782662e-16,1.3157901523403177e-16,9.203775583921567e-17,3.5272682291948935e-16,4.438343769976764e-16,1.7651375248785403e-16,4.828636082475104e-17],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"steelblue\",\"width\":1.5},\"name\":\"lines\"}],\"layout\":{\"title\":{\"text\":\"AM Spectrum (peaks at 35, 40, 45 Hz)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Frequency (Hz)\"},\"range\":[0.0,128.0],\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Amplitude\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
