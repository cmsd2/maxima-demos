6136459222595016e-33,1.2100205016886137e-33,1.1510843225000028e-33,8.623731879200392e-35,4.57700927265228e-34,4.516043695670378e-33,2.011039543269527e-33,3.549593830592466e-33,3.0251403943037022e-33,5.616542724947349e-33,2.5381665808826425e-32,2.4275540967803068e-33,2.8187039222573448e-33,6.0416065217556e-33,2.4418795186674618e-33,1.00706347079304e-34,3.12035360483617e-33,8.937458688486658e-34,2.181202590363146e-33,2.735897720160816e-33,3.175554363233213e-34],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"darkgreen\",\"width\":1.5},\"name\":\"lines\"}],\"layout\":{\"title\":{\"text\":\"Power Spectral Density\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Frequency (Hz)\"},\"range\":[0.0,128.0],\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Power / Hz\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
