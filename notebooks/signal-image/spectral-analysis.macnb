6791,-146.82038407753686,-147.32514384844538,-147.83745076642063,-148.35848809318162,-148.88959487587238,-149.43229539779165,-149.9883357055592,-150.5597299002059,-151.14881818862472,-151.75834230425562,-152.39154269186776,-153.05228799191465,-153.7452483238359,-154.4761328794407,-155.25202245041024,-156.08184615733947,-156.9770846707704,-157.95284296380896,-159.02955205829196,-160.23580257412686,-161.61334776829395,-163.2266300785436,-165.18280331816783,-167.6799550151628,-171.14899413666762,-176.8241751358475,-186.62752507621],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"crimson\",\"width\":1.5},\"name\":\"Hann window\"}],\"layout\":{\"title\":{\"text\":\"Spectral Leakage: Rectangular vs Hann Window\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Frequency (Hz)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Magnitude (dB)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
