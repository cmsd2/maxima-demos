,0.018640586344514244,0.0,0.020013135570052003,0.0,0.04484547151379483,0.0,0.01563559492008819,0.0,0.05610016309618407,0.0,0.01894882694600455,0.0,0.019633419749086563,0.0,0.04803106565164047,0.0,0.01562617662236094,0.0,0.05173739138325377,0.0,0.019279241437658447,0.0],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"purple\",\"width\":1.5},\"name\":\"lines\"}],\"layout\":{\"title\":{\"text\":\"Square Wave Spectrum (odd harmonics only)\"},\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"Frequency (Hz)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"Amplitude\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
